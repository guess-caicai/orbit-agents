OPENAI_API_KEY=your_key
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=
DASHSCOPE_API_KEY=your_key
DASHSCOPE_ASR_MODEL=paraformer-realtime-v1

EMAIL_HOST=smtp.qq.com
EMAIL_USER=you@example.com
EMAIL_PASSWORD=your_password
EMAIL_PORT=465

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database
MYSQL_POOL_SIZE=10

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j
NEO4J_DB=neo4j

CHROMA_PATH=../chroma_db
CHROMA_COLLECTION3=HuatuoGPT

VISION_MODEL=qwen-vl-plus

LOCAL_VL_MODEL_PATH=

FFMPEG_PATH=D:/path/to/ffmpeg.exe

# reranker: local | remote | hybrid
RERANKER_PROVIDER=local
# default path is backend/models/bge-reranker-v2-m3
# RERANKER_MODEL_PATH=

# graph assistant safety/config
GRAPH_READONLY=true
GRAPH_QUERY_LIMIT=200
